{
  "name": "agentic-engineering-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "check": "biome check --write src/ features/ migrations/ *.json *.cjs *.md",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.features.json",
    "test": "LD_LIBRARY_PATH=/tmp/opencode/libfix/usr/lib/x86_64-linux-gnu cucumber-js",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.0",
    "hono": "^4.8.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@cucumber/cucumber": "^11.3.0",
    "@types/node": "^22.15.0",
    "playwright": "^1.53.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.22.0"
  }
}
